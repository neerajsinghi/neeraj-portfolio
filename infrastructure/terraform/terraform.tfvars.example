aws_region   = "us-east-1"
project      = "neeraj-portfolio"
environment  = "prod"

github_repo         = "https://github.com/neerajsinghi/neeraj-portfolio"
github_org_repo     = "neerajsinghi/neeraj-portfolio"
github_access_token = "ghp_xxxxxxxxxxxxxxxxxxxx"   # GitHub PAT with repo scope

api_base_url = "https://api.your-domain.com"       # backend LoadBalancer URL after first deploy

eks_node_instance_type = "t3.small"
eks_desired_nodes      = 2
eks_min_nodes          = 1
eks_max_nodes          = 4
