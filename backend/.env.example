# ── Anthropic ────────────────────────────────────────────────────────────────
# Required when using the Anthropic provider (default).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required when using the OpenAI provider.
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_MODEL=gpt-4o

# ── xAI / Grok ───────────────────────────────────────────────────────────────
# Required when using the Grok provider.
XAI_API_KEY=xai-xxxxxxxx
GROK_MODEL=grok-3

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required when using the Gemini provider.
GEMINI_API_KEY=AIzaxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# ── Server ───────────────────────────────────────────────────────────────────
GITHUB_USER=neerajsinghi
# GITHUB_TOKEN=ghp_xxxx       # optional: raises the GitHub API rate limit
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000
